{
  "manifest_version": 3,
  "name": "ZoomSense",
  "version": "1.1.0",
  "description": "Automatically sets the right zoom level for each monitor. 100% on your laptop, 150% on your big screen — hands-free.",

  "permissions": [
    "tabs",
    "storage",
    "system.display",
    "windows",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "action": {
    "default_title": "ZoomSense",
    "default_popup": "popup.html"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
